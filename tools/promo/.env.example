# Copy this file to tools/promo/.env (gitignored) and fill in real values.
#
# PROMO_SERVICE_URL — the deployed Apps Script Web App URL. Same URL the
# add-on uses for redemption. Find it in the standalone admin/service
# project: Deploy -> Manage deployments -> copy the Web app URL.
PROMO_SERVICE_URL=https://script.google.com/macros/s/AKfyc.../exec

# PROMO_ADMIN_TOKEN — the token you saved when running configureAdminToken
# in the standalone project. NOT the same as the add-on's SERVICE_TOKEN.
PROMO_ADMIN_TOKEN=replace-with-the-random-hex-token-from-configureAdminToken

# PROMO_SHEET_ID — Google Sheets ID of the Codes spreadsheet. Optional; when
# set, the batch page renders an "Open spreadsheet" link that opens the sheet
# in a new tab. Find the value in the standalone admin/service Apps Script
# project's Script Properties under PROMO_SHEET_ID.
PROMO_SHEET_ID=

# PROMO_CODES_DIR — relative path (from this file's directory) or absolute
# path to the local batch tracking files. Default '../../promo_codes' points
# at promo_codes/ at the repo root, which is gitignored.
PROMO_CODES_DIR=../../promo_codes

# Server bind host / port — localhost-only by default. Do not change unless
# you have hardened the server with auth (it is single-user with no auth).
PROMO_BIND_HOST=127.0.0.1
PROMO_BIND_PORT=5057
