# ─────────────────────────────────────────────────────────────────────────────
# emAIl Sentinel — SMS Provider Preflight Config
# Copy to sms_preflight.env and fill in your own developer credentials.
# Never commit sms_preflight.env — it is in .gitignore.
#
# Only fill in the providers you have accounts for. Blank values are skipped
# by validate_sms_providers.sh.
#
# DEV_PHONE_NUMBER / DEV_PHONE_COUNTRY: your own mobile number that the
# validation script will send test SMS messages to. Digits only (no country
# code, no spaces, no dashes).
# ─────────────────────────────────────────────────────────────────────────────

DEV_PHONE_COUNTRY=+1
DEV_PHONE_NUMBER=

# ── Twilio ────────────────────────────────────────────────────────────────────
# Console → Account Info panel on dashboard. From number: active Twilio number.
# A2P 10DLC must be registered + approved for US-to-US delivery.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_COUNTRY=+1
TWILIO_FROM_NUMBER=

# ── Telnyx ────────────────────────────────────────────────────────────────────
# Portal → API Keys (V2 key). From number: active number with a Messaging
# Profile assigned (Portal → Phone Numbers → click number → Messaging Profile).

TELNYX_API_KEY=
TELNYX_FROM_COUNTRY=+1
TELNYX_FROM_NUMBER=

# ── Plivo ─────────────────────────────────────────────────────────────────────
# Console → Overview. From number: active Plivo number.

PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_COUNTRY=+1
PLIVO_FROM_NUMBER=

# ── ClickSend ─────────────────────────────────────────────────────────────────
# Dashboard → Developers → API Credentials.
# No "From" number required — ClickSend uses the account username as sender.

CLICKSEND_USERNAME=
CLICKSEND_API_KEY=

# ── Vonage ────────────────────────────────────────────────────────────────────
# Dashboard → API Settings. Free-trial accounts require the destination number
# to be added as a test number (Dashboard → Test numbers) before SMS works.

VONAGE_API_KEY=
VONAGE_API_SECRET=

# ── Textbelt ──────────────────────────────────────────────────────────────────
# Free tier: use the literal string "textbelt" (1 SMS/day shared limit).
# Paid: your paid API token from textbelt.com.

TEXTBELT_API_KEY=textbelt
