.DS_Store
node_modules/
*.swp

# Google Apps Script / clasp local config
.clasp.json
.clasprc.json

# Cloudflare wrangler local cache + build artifacts (testing/mcp-loopback/)
.wrangler/

# Private working dir: secrets, internal strategy, historical test artifacts.
# Do not move files out of here unless they are confirmed free of API keys,
# credentials, internal strategy notes, or Gmail-account PII.
work/

# UserTesting per-round artifacts that contain secrets or PII:
#   outgoing/  — filled task scripts with real Gemini API key + deployment URL
#   incoming/  — downloaded session recordings, transcripts (tester PII)
# Both directories themselves are kept (via .gitkeep + README.md) so the
# structure survives a fresh clone; only their working contents are ignored.
usertesting/outgoing/*
usertesting/incoming/*
!usertesting/outgoing/.gitkeep
!usertesting/outgoing/README.md
!usertesting/incoming/.gitkeep
!usertesting/incoming/README.md

# Pro promo codes minted for any batch (UserTesting rounds, founding-member
# offers, customer gifts, refund-replacement codes, etc.). Each code is
# single-use and grants Pro tier on redemption. Treat as batch-scoped
# credentials (mint / assign to one recipient / void unredeemed at batch
# close). Never commit.
promo_codes/

# Local Python admin tool — env file holds PROMO_ADMIN_TOKEN (a master key
# that can mint / void / assign codes) and PROMO_SERVICE_URL.
tools/promo/.env

# SMS provider preflight credentials — contains API keys, auth tokens, and
# the developer's personal mobile number for test SMS dispatch.
tools/preflight/sms_preflight.env
tools/promo/__pycache__/
tools/promo/**/__pycache__/

# Marketing internal strategy (not for public repo)
marketing/marketing_plan.md

# Large binary media files (video, PDF) — store outside git or use LFS
marketing/media/**/*.mp4
marketing/media/**/*.pdf
